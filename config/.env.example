# NEURAL-CLAW Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# Gateway authentication (auto-generated by setup.sh)
OPENCLAW_GATEWAY_TOKEN=

# ChromaDB auth token for Hippocampus memory store
CHROMA_SERVER_AUTH_CREDENTIALS=

# ── Optional: Cloud Inference Fallback ──────────────────────────────
# Uncomment and set if you want cloud model fallback
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# NVIDIA_API_KEY=

# ── Optional: NemoClaw Security Layer ───────────────────────────────
# NIM_API_KEY=
# TELEGRAM_BOT_TOKEN=
# NEMOCLAW_GPU=
