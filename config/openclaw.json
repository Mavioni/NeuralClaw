{
  "$schema": "https://openclaw.dev/schema/config.json",
  "gateway": {
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "type": "bearer",
      "envVar": "OPENCLAW_GATEWAY_TOKEN"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        },
        "responses": {
          "enabled": true
        }
      }
    }
  },
  "models": {
    "default": {
      "provider": "ollama",
      "endpoint": "http://neural_ollama:11434",
      "model": "llama3.2:3b"
    },
    "fast": {
      "provider": "ollama",
      "endpoint": "http://neural_ollama:11434",
      "model": "phi4-mini"
    },
    "embed": {
      "provider": "ollama",
      "endpoint": "http://neural_ollama:11434",
      "model": "nomic-embed-text"
    }
  },
  "memory": {
    "provider": "chromadb",
    "endpoint": "http://neural_hippo:8000",
    "auth": {
      "type": "bearer",
      "envVar": "CHROMA_SERVER_AUTH_CREDENTIALS"
    }
  },
  "security": {
    "toolApproval": "auto",
    "maxConcurrentAgents": 5,
    "maxTokensPerRequest": 4096
  }
}
